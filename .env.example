# Copy to .env for local runs:  set -a; . ./.env; set +a; python -m wikisync
# In GitHub Actions, set these as repository Variables, except *_TOKEN which are Secrets.

# --- Core (required) ---
WIKIPEDIA_USERNAME=Jimbo Wales      # the Wikipedia user whose edits to sync

# --- Core (optional) ---
WIKIPEDIA_LANG=en                   # language edition(s); host becomes <lang>.wikipedia.org
                                    # comma-separate to sync several at once, e.g.:
                                    #   WIKIPEDIA_LANG=en,ru,be,be-tarask
                                    # (note the hyphen in be-tarask; each wiki syncs independently)
# WIKIPEDIA_HOST=commons.wikimedia.org,meta.wikimedia.org   # override for non-Wikipedia wikis (takes precedence)
EXPORT_TARGETS=evernote             # comma-separated: evernote,notion,stdout
EXPORT_DEDUP=true                   # skip edits already exported (per sink)
MAX_EDITS_PER_RUN=50                # cap per run; the rest sync on following runs
FIRST_RUN_LOOKBACK_DAYS=7           # on the very first run, only edits newer than this
# NOTE_TITLE_TEMPLATE={title} — {date:%Y-%m-%d %H:%M} ({sizediff:+d} B)
# WIKIPEDIA_USER_AGENT=wikipedia-diffs-to-evernote/1.0 (you@example.com)
#   Wikimedia asks for a contact; a good UA reduces 429 rate-limiting.
#   In GitHub Actions set this as a SECRET (not a Variable) if it contains your
#   email and the repo is public — the workflow reads secret first, then var.
LOG_LEVEL=INFO

# --- Evernote sink ---
EVERNOTE_DEV_TOKEN=                 # SECRET: your Evernote developer token (Premium)
# EVERNOTE_NOTEBOOK=Wikipedia edits # notebook name (created if missing); omit for default
# EVERNOTE_TAGS=wikipedia,edits     # comma-separated tags applied to each note
# EVERNOTE_SANDBOX=false            # true to target sandbox.evernote.com
# EVERNOTE_SERVICE_HOST=www.evernote.com   # use app.yinxiang.com for Evernote China

# --- Notion sink (optional reference implementation) ---
# NOTION_TOKEN=                     # SECRET: Notion internal integration token
# NOTION_DATABASE_ID=               # target database id (shared with the integration)
